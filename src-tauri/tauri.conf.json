{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoE2 Campaign Tracker",
  "version": "0.2.0",
  "identifier": "com.poe2campaigntracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PoE2 Campaign Tracker",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBRTkxQkE1QkM0MjRCRUUKUldUdVMwSzhwUnZwaWhZZHY2anZ3dExZbHJsTFRqVGZJSTRkTTZwMHV3bHJaWjlCZlMzaHJDZmUK",
      "endpoints": [
        "https://github.com/matthewloverton/poe2campaigntracker/releases/latest/download/latest.json"
      ]
    }
  }
}
